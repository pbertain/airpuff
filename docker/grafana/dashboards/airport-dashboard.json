          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "SELECT\n  CASE \n    WHEN flight_category = 'VFR' THEN 1\n    WHEN flight_category = 'MVFR' THEN 2\n    WHEN flight_category = 'IFR' THEN 3\n    WHEN flight_category = 'LIFR' THEN 4\n    ELSE 0\n  END as \"Flight Category\"\nFROM weather_observations\nWHERE icao_code = '${airport:raw}'\nORDER BY observed_time DESC\nLIMIT 1",
          "refId": "A",
          "select": [
            [
              {
                "params": [
                  "value"
                ],
                "type": "column"
              }
            ]
          ],
          "timeColumn": "time",
          "where": [
            {
              "name": "$__timeFilter",
              "params": [],
              "type": "macro"
            }
          ]
        }
      ],
