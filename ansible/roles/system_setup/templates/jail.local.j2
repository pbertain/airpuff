# Fail2ban Configuration for AirPuff
# Generated by Ansible

[DEFAULT]
bantime = {{ fail2ban_bantime | default(3600) }}
findtime = {{ fail2ban_findtime | default(600) }}
maxretry = {{ fail2ban_max_retry | default(3) }}

[sshd]
enabled = true
port = ssh
logpath = /var/log/auth.log
maxretry = 3
bantime = 3600

[nginx-http-auth]
enabled = true
port = http,https
logpath = /var/log/nginx/error.log
maxretry = 3
bantime = 3600

[nginx-limit-req]
enabled = true
port = http,https
logpath = /var/log/nginx/error.log
maxretry = 10
bantime = 600

[airpuff-app]
enabled = true
port = {{ airpuff_app_port }}
logpath = {{ airpuff_app_logs }}/access.log
maxretry = 10
bantime = 3600
findtime = 600
