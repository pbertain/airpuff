# AirPuff Logrotate Configuration
# Generated by Ansible

{{ airpuff_app_logs }}/*.log {
    daily
    missingok
    rotate {{ logrotate_keep_days | default(30) }}
    compress
    delaycompress
    notifempty
    create 644 {{ airpuff_app_user }} {{ airpuff_app_group }}
    postrotate
        systemctl reload airpuff-app || true
    endscript
}

