# AirPuff Environment Configuration
# Generated by Ansible

# Database Configuration
DATABASE_URL=postgresql://{{ postgresql_db_user }}:{{ postgresql_db_password }}@localhost:{{ airpuff_timescaledb_port }}/{{ postgresql_db_name }}
TIMESCALEDB_URL=postgresql://{{ postgresql_db_user }}:{{ postgresql_db_password }}@localhost:{{ airpuff_timescaledb_port }}/{{ postgresql_db_name }}

# Redis Configuration
REDIS_URL=redis://localhost:{{ airpuff_redis_port }}

# Application Configuration
SECRET_KEY={{ airpuff_secret_key }}
ENVIRONMENT={{ airpuff_environment | default(environment) }}
DEBUG={{ debug | lower }}
LOG_LEVEL={{ log_level }}
HOST=0.0.0.0
PORT={{ airpuff_app_port }}

# API Keys
FLI_RITE_API_KEY={{ vault_fli_rite_api_key | default('') }}
CHECKWX_API_KEY={{ vault_checkwx_api_key | default('') }}

# OAuth Configuration
GOOGLE_CLIENT_ID={{ vault_google_client_id | default('') }}
GOOGLE_CLIENT_SECRET={{ vault_google_client_secret | default('') }}
APPLE_CLIENT_ID={{ vault_apple_client_id | default('') }}
APPLE_CLIENT_SECRET={{ vault_apple_client_secret | default('') }}

# OIDC (Keycloak via cloudpuff)
OIDC_ISSUER={{ airpuff_oidc_issuer | default('') }}
OIDC_CLIENT_ID={{ airpuff_oidc_client_id | default('airpuff-web') }}
OIDC_CLIENT_SECRET={{ airpuff_oidc_client_secret | default('') }}
OIDC_REDIRECT_URI={{ airpuff_oidc_redirect_uri | default('') }}
SESSION_SECRET={{ airpuff_session_secret | default(airpuff_secret_key, true) }}
BASE_URL={{ airpuff_base_url | default('http://localhost') }}

# iMessage Configuration
IMESSAGE_BRIDGE_URL={{ vault_imessage_bridge_url | default('') }}
IMESSAGE_API_KEY={{ vault_imessage_api_key | default('') }}

# Grafana Configuration
GRAFANA_URL=http://localhost:{{ airpuff_grafana_port }}
GRAFANA_USERNAME={{ grafana_admin_user }}
GRAFANA_PASSWORD={{ grafana_admin_password }}

# Security Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# WebSocket Configuration
WEBSOCKET_PING_INTERVAL=25
WEBSOCKET_PING_TIMEOUT=20

# Performance Configuration
WORKERS={{ airpuff_workers | default(2) }}
MAX_REQUESTS={{ airpuff_max_requests | default(1000) }}
MAX_REQUESTS_JITTER={{ airpuff_max_requests_jitter | default(100) }}
