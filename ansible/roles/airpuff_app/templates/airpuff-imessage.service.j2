[Unit]
Description=AirPuff iMessage Scheduled Message Processor
After=network.target postgresql.service redis.service airpuff-app.service
Wants=postgresql.service redis.service airpuff-app.service

[Service]
Type=oneshot
User={{ airpuff_app_user }}
Group={{ airpuff_app_group }}
WorkingDirectory={{ airpuff_app_home }}/backend
Environment=PATH={{ virtualenv_path }}/bin
ExecStart={{ virtualenv_path }}/bin/python -c "
import asyncio
import sys
sys.path.append('{{ airpuff_app_home }}/backend')
from app.services.imessage_service import imessage_service

async def main():
    await imessage_service.process_scheduled_messages()

asyncio.run(main())
"
StandardOutput=journal
StandardError=journal
SyslogIdentifier=airpuff-imessage

# Security settings
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths={{ airpuff_app_home }} {{ airpuff_app_logs }} {{ airpuff_app_data }}

# Resource limits
LimitNOFILE=65536
LimitNPROC=32768

[Install]
WantedBy=multi-user.target
