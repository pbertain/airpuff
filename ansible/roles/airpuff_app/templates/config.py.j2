"""Configuration management for AirPuff application."""

import os
from typing import Optional
from pydantic_settings import BaseSettings


class Settings(BaseSettings):
    """Application settings loaded from environment variables."""
    
    # Database
    database_url: str = "postgresql://{{ postgresql_db_user }}:{{ postgresql_db_password }}@localhost:{{ airpuff_timescaledb_port }}/{{ postgresql_db_name }}"
    timescaledb_url: str = "postgresql://{{ postgresql_db_user }}:{{ postgresql_db_password }}@localhost:{{ airpuff_timescaledb_port }}/{{ postgresql_db_name }}"
    
    # Redis Configuration
    redis_url: str = "redis://localhost:{{ airpuff_redis_port }}"
    
    # API Keys
    fli_rite_api_key: Optional[str] = None
    checkwx_api_key: Optional[str] = None
    
    # OAuth
    google_client_id: Optional[str] = None
    google_client_secret: Optional[str] = None
    apple_client_id: Optional[str] = None
    apple_client_secret: Optional[str] = None
    
    # Security
    secret_key: str = "{{ airpuff_secret_key }}"
    algorithm: str = "HS256"
    access_token_expire_minutes: int = 30
    
    # iMessage
    imessage_bridge_url: Optional[str] = None
    imessage_api_key: Optional[str] = None
    
    # Environment
    environment: str = "{{ deployment_env }}"
    debug: bool = {% if debug %}True{% else %}False{% endif %}
    
    # Server configuration
    host: str = "0.0.0.0"
    port: int = {{ airpuff_app_port }}
    
    # WebSocket
    websocket_ping_interval: int = 25
    websocket_ping_timeout: int = 20
    
    # Grafana Configuration
    grafana_url: str = "http://localhost:{{ airpuff_grafana_port }}"
    grafana_username: str = "{{ grafana_admin_user }}"
    grafana_password: str = "{{ grafana_admin_password }}"
    
    # Performance Configuration
    workers: int = {{ airpuff_workers | default(2) }}
    max_requests: int = {{ airpuff_max_requests | default(1000) }}
    max_requests_jitter: int = {{ airpuff_max_requests_jitter | default(100) }}
    
    class Config:
        env_file = ".env"
        case_sensitive = False


# Global settings instance
settings = Settings()
