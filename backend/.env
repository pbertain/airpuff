# Database Configuration (using SQLite for development)
DATABASE_URL=sqlite:///./airpuff.db
TIMESCALEDB_URL=sqlite:///./airpuff.db

# API Keys (placeholder values)
FLI_RITE_API_KEY=your_fli_rite_api_key_here
CHECKWX_API_KEY=your_checkwx_api_key_here

# OAuth Configuration (placeholder values)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
APPLE_CLIENT_ID=your_apple_client_id_here
APPLE_CLIENT_SECRET=your_apple_client_secret_here

# Security
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# iMessage Integration (placeholder values)
IMESSAGE_BRIDGE_URL=http://your-mac-server:8080
IMESSAGE_API_KEY=your_imessage_api_key_here

# Environment
ENVIRONMENT=development
DEBUG=true

# WebSocket Configuration
WEBSOCKET_PING_INTERVAL=25
WEBSOCKET_PING_TIMEOUT=20
